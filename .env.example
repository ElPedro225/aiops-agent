# AIOps Agent — Environment Variables
# Copy this file to .env and fill in your values

# === LLM API Keys (optional — agent works without these) ===
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === LLM Model (optional — defaults to claude-haiku for cost efficiency) ===
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Anomaly Detection Thresholds ===
ANOMALY_HIGH_THRESHOLD=0.75
ANOMALY_LOW_THRESHOLD=0.40
Z_SCORE_THRESHOLD=3.0

# === Simulation Settings ===
SIM_REFERENCE_SAMPLES=500
SIM_CURRENT_SAMPLES=100
SIM_RANDOM_SEED=42
SIM_INJECT_ANOMALY=true

# === Action Settings ===
ENABLE_AUTO_ACTIONS=false     # Set true only when confident
HUMAN_APPROVAL_REQUIRED=true

# === Push Notifications (ntfy.sh) ===
# Set NTFY_TOPIC to enable mobile push alerts on anomaly detection.
# Step 1: Install ntfy app on your phone (Android: free, iOS: $1.99)
# Step 2: Subscribe to your topic in the app (e.g. aiops-alerts-yourname)
# Step 3: Set NTFY_TOPIC below and run the agent
# Leave blank to disable notifications entirely (opt-in).
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
NOTIFY_MIN_SCORE=0.40         # Only notify when anomaly_score >= this value
NOTIFY_DECISIONS=AUTO,CONFIRM,ESCALATE

# === Alert Deduplication ===
# Suppress repeat notifications for the same (service, decision) within this window.
# Set to 0 to disable deduplication (useful for testing that notifications fire).
ALERT_COOLDOWN_MINUTES=5

# === Continuous Loop Mode ===
# Used when running: python main.py --loop
AGENT_LOOP_INTERVAL_SECONDS=60
