# AIOps Agent — Environment Variables
# Copy this file to .env and fill in your values

# === LLM API Keys (optional — agent works without these) ===
ANTHROPIC_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# === Anomaly Detection Thresholds ===
ANOMALY_HIGH_THRESHOLD=0.75
ANOMALY_LOW_THRESHOLD=0.40
Z_SCORE_THRESHOLD=3.0

# === Drift Monitor Settings ===
DRIFT_TOLERANCE=0.30
DRIFT_REPORT_DIR=reports/
DRIFT_CHECK_INTERVAL_MINUTES=5

# === Simulation Settings ===
SIM_REFERENCE_SAMPLES=500
SIM_CURRENT_SAMPLES=100
SIM_RANDOM_SEED=42
SIM_INJECT_ANOMALY=true

# === Action Settings ===
ENABLE_AUTO_ACTIONS=false     # Set true only when confident
HUMAN_APPROVAL_REQUIRED=true
