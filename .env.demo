# Demo scenarios for the AIOps agent.
# Activate by copying this file to .env:
#   cp .env.demo .env
# Then keep one scenario block active at a time.

# ============================================================
# Scenario A: Mild anomaly, no drift (higher trust requirement)
# ============================================================
SIM_INJECT_ANOMALY=true
ANOMALY_HIGH_THRESHOLD=0.85
DRIFT_TOLERANCE=0.50
ENABLE_AUTO_ACTIONS=false
HUMAN_APPROVAL_REQUIRED=true

# ============================================================
# Scenario B: Severe anomaly with drift (lower anomaly threshold,
# stricter drift tolerance)
# To use Scenario B, comment out Scenario A values above and
# uncomment the values below.
# ============================================================
# SIM_INJECT_ANOMALY=true
# ANOMALY_HIGH_THRESHOLD=0.55
# DRIFT_TOLERANCE=0.10
# ENABLE_AUTO_ACTIONS=false
# HUMAN_APPROVAL_REQUIRED=true
